{
  "name": "client-editor-app",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "npm run env:local && vite",
    "build": "npm run build:local",
    "preview": "vite preview",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "env:local": "cross-env ENV_NAME=local node scripts/generate-env.js",
    "env:dev": "cross-env ENV_NAME=dev node scripts/generate-env.js",
    "env:uat": "cross-env ENV_NAME=uat node scripts/generate-env.js",
    "env:stage": "cross-env ENV_NAME=stage node scripts/generate-env.js",
    "env:prod": "cross-env ENV_NAME=prod node scripts/generate-env.js",
    "build:local": "npm run env:local && vite build",
    "build:dev": "npm run env:dev && vite build",
    "build:uat": "npm run env:uat && vite build",
    "build:stage": "npm run env:stage && vite build",
    "build:prod": "npm run env:prod && vite build",
    "env:validate": "node scripts/validate-env.js",
    "postbuild": "node scripts/post-build-env.js",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:debug": "playwright test --debug",
    "test:e2e:chrome": "playwright test --project=chromium",
    "test:e2e:firefox": "playwright test --project=firefox",
    "test:e2e:webkit": "playwright test --project=webkit",
    "test:e2e:overlay": "playwright test tests/overlay/",
    "test:e2e:module": "playwright test tests/modules/",
    "test:e2e:error": "playwright test tests/error/",
    "test:e2e:accessibility": "playwright test tests/accessibility/",
    "test:report": "playwright show-report",
    "test:codegen": "playwright codegen"
  },
  "dependencies": {
    "@fontsource/source-sans-pro": "^5.0.8",
    "ag-grid-community": "^31.0.0",
    "ag-grid-react": "^31.0.0",
    "axios": "^1.6.2",
    "bootstrap": "^5.3.2",
    "ckeditor4-react": "^5.2.1",
    "framer-motion": "^12.34.0",
    "jquery": "^3.7.1",
    "lucide-react": "^0.294.0",
    "moment": "^2.29.4",
    "mustache": "^4.2.0",
    "popper.js": "^1.16.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "summernote": "^0.8.20",
    "sweetalert2": "^11.10.1",
    "sweetalert2-react-content": "^5.0.7",
    "tempusdominus-bootstrap-4": "^5.39.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.8.0",
    "@playwright/test": "^1.40.0",
    "@types/react": "^18.2.37",
    "@types/react-dom": "^18.2.15",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "axe-core": "^4.8.0",
    "cross-env": "^7.0.3",
    "esbuild": "^0.27.3",
    "eslint": "^8.53.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.4",
    "postcss": "^8.4.31",
    "tailwindcss": "^3.3.5",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vite-plugin-html": "^3.2.2"
  }
}
